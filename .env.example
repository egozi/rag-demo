# ── API Keys / Secrets ────────────────────────────────────────────────────────
# These are the ONLY values that belong in .env.
# All other parameters (model names, hosts, ports, thresholds) have defaults in
# api/config.py and can be overridden via environment variables when needed.

# Required for RAGAS evaluation judge and (in openai mode) for LLM + embeddings
OPENAI_API_KEY=sk-...

# Get from the Langfuse dashboard after first login (see SETUP.md).
# Leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...

# ── Docker Compose secrets (docker-compose.yml only) ─────────────────────────
# Change these when deploying to GCP; defaults in the compose files are fine locally.
# LANGFUSE_NEXTAUTH_SECRET=change-me-in-prod
# LANGFUSE_SALT=change-me-in-prod
