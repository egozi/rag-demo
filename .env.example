# ── Mode ──────────────────────────────────────────────────────────────────────
# "openai" uses OpenAI for both LLM and embeddings (easiest for local testing)
# "ollama" uses a local Ollama server for LLM and embeddings (required for GCP)
LLM_BACKEND=openai

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required for RAGAS evaluation judge in both modes; also used for LLM+embeddings
# when LLM_BACKEND=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ── Ollama ────────────────────────────────────────────────────────────────────
# Only needed when LLM_BACKEND=ollama
# In Docker: OLLAMA_HOST=http://ollama:11434
# Locally:   OLLAMA_HOST=http://localhost:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAGAS ─────────────────────────────────────────────────────────────────────
# Evaluation judge is always OpenAI (avoids self-grading bias)
RAGAS_MODEL=gpt-4o

# ── Langfuse (self-hosted observability) ──────────────────────────────────────
# Get keys from the Langfuse dashboard after first login (see SETUP.md)
# In Docker: LANGFUSE_HOST=http://langfuse:3000
# Locally:   LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_ENABLED=true

# ── Qdrant ────────────────────────────────────────────────────────────────────
# In Docker: QDRANT_HOST=qdrant
# Locally:   QDRANT_HOST=localhost
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=rag_demo

# ── Conversation history ──────────────────────────────────────────────────────
HISTORY_DB=data/history.db
SHORT_TERM_TURNS=6       # keep last N turns verbatim in the prompt
LONG_TERM_THRESHOLD=12   # compress older turns into a summary when total exceeds this
